generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/*
|--------------------------------------------------------------------------
| ENUMS
|--------------------------------------------------------------------------
*/

enum UserRole {
  ADMIN
  MEMBER
}

enum ProjectRole {
  PROJECT_ADMIN
  PROJECT_MEMBER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  COMPLETED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}