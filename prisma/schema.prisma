generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/*
|--------------------------------------------------------------------------
| ENUMS
|--------------------------------------------------------------------------
*/

enum UserRole {
  ADMIN
  MEMBER
}

enum ProjectRole {
  PROJECT_ADMIN
  PROJECT_MEMBER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  COMPLETED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model User {
  id String @id @default(uuid())

  fullname String
  username String @unique
  email    String @unique
  password String

  avatar String?

  role UserRole @default(MEMBER)

  /*
  |--------------------------------------------------------------------------
  | RELATIONS
  |--------------------------------------------------------------------------
  */

  createdProjects Project[]

  memberships ProjectMember[]

  assignedTasks Task[]

  activityLogs ActivityLog[]

  comments Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}